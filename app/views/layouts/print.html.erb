<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LegionPostTools" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
