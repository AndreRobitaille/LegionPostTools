<h1>People</h1>

<p>Roster-backed member records keep imported Legion data in read-only fields until a later workflow updates them.</p>

<% if @roster_stale %>
  <p role="alert">The roster is more than 30 days old or has not been imported yet. Upload a current National roster export.</p>
<% end %>

<%= form_with url: admin_people_path, method: :get do |form| %>
  <p>
    <%= form.label :q, "Search" %>
    <%= form.search_field :q, value: params[:q] %>
    <%= form.submit "Search" %>
  </p>
  <p>
    <%= form.label :roster_member_status, "Member status" %>
    <%= form.text_field :roster_member_status, value: params[:roster_member_status] %>
    <%= form.label :roster_paid_through_year, "Paid through year" %>
    <%= form.text_field :roster_paid_through_year, value: params[:roster_paid_through_year] %>
    <%= form.label :roster_branch, "Branch" %>
    <%= form.text_field :roster_branch, value: params[:roster_branch] %>
    <%= form.label :login_status, "Login status" %>
    <%= form.select :login_status, options_for_select([ ["Any", ""], ["Enabled", "enabled"], ["Disabled", "disabled"], ["No login", "no_login"] ], params[:login_status]) %>
    <%= form.submit "Filter" %>
  </p>
<% end %>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Member ID</th>
      <th>Status</th>
      <th>Paid through</th>
      <th>Login</th>
    </tr>
  </thead>
  <tbody>
    <% @people.each do |person| %>
      <tr>
        <td><%= link_to person.roster_display_name, admin_person_path(person) %></td>
        <td><%= person.member_number %></td>
        <td><%= person.roster_member_status %></td>
        <td><%= person.roster_paid_through_year %></td>
        <td>
          <%= if person.user.nil?
                "No login"
              elsif person.user.disabled_at.present?
                "Disabled"
              else
                "Enabled"
              end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
