<h1><%= @person.roster_display_name %></h1>

<dl>
  <dt>Member ID</dt>
  <dd><%= @person.member_number %></dd>

  <dt>Name</dt>
  <dd><%= @person.roster_name.presence || @person.full_name %></dd>

  <dt>Post/Squadron</dt>
  <dd><%= @person.roster_post %></dd>

  <dt>Type</dt>
  <dd><%= @person.roster_membership_type %></dd>

  <dt>Status</dt>
  <dd><%= @person.roster_member_status %></dd>

  <dt>Paid through</dt>
  <dd><%= @person.roster_paid_through_year %></dd>

  <dt>Email</dt>
  <dd><%= @person.roster_email_address %></dd>

  <dt>Phone</dt>
  <dd><%= @person.roster_phone_number %></dd>

  <dt>Branch</dt>
  <dd><%= @person.roster_branch %></dd>

  <dt>Conflict/War Era</dt>
  <dd><%= @person.roster_war_era %></dd>

  <dt>Continuous years</dt>
  <dd><%= @person.roster_continuous_years %></dd>

  <dt>Undeliverable</dt>
  <dd><%= @person.roster_undeliverable? ? "Yes" : "No" %></dd>

  <dt>Address</dt>
  <dd><%= @person.roster_address %></dd>

  <dt>Imported</dt>
  <dd><%= @person.roster_imported_at ? l(@person.roster_imported_at, format: :long) : nil %></dd>
</dl>

<section>
  <h2>Login account</h2>

  <% if @user.present? %>
    <p>Email: <%= @user.email_address %></p>
    <p>Status: <%= @user.disabled_at.present? ? "Disabled" : "Enabled" %></p>

    <% if @user.roster_email_mismatch? %>
      <p role="alert">Roster email address does not match the login email address.</p>
    <% end %>

    <% if @user.disabled_at.present? %>
      <%= form_with url: admin_person_user_account_path(@person), scope: :user do |form| %>
        <p>
          <%= form.label :email_address, "Login email" %>
          <%= form.email_field :email_address, value: @user.email_address %>
        </p>
        <%= form.submit "Re-enable login" %>
      <% end %>
    <% else %>
      <%= button_to "Disable login", admin_person_user_account_path(@person), method: :delete %>
    <% end %>

    <%= form_with url: admin_user_permission_grants_path(@user), method: :patch do |form| %>
      <% PermissionGrant::CAPABILITIES.each do |capability| %>
        <p>
          <%= check_box_tag "permission_grant[capabilities][]", capability, @user.can?(capability), id: "permission_grant_capabilities_#{capability}" %>
          <%= label_tag "permission_grant_capabilities_#{capability}", capability.humanize %>
        </p>
      <% end %>
      <%= form.submit "Update permissions" %>
    <% end %>
  <% else %>
    <%= form_with url: admin_person_user_account_path(@person), scope: :user do |form| %>
      <p>
        <%= form.label :email_address, "Login email" %>
        <%= form.email_field :email_address, value: @person.roster_email_address %>
      </p>
      <%= form.submit "Enable login" %>
    <% end %>
  <% end %>
</section>

<section>
  <h2>Post roles</h2>

  <% if @person.position_assignments.any? %>
    <ul>
      <% @person.position_assignments.includes(:position_title).order(:starts_on, :id).each do |assignment| %>
        <li>
          <strong><%= assignment.position_title.name %></strong>
          <span><%= assignment.starts_on %></span>
          <span><%= assignment.ends_on.present? ? assignment.ends_on : "Present" %></span>

          <% if assignment.ends_on.blank? %>
            <%= form_with url: admin_person_position_assignment_path(@person, assignment), method: :patch, scope: :position_assignment do |form| %>
              <%= form.label :ends_on, "End date" %>
              <%= form.date_field :ends_on %>
              <%= form.submit "End role" %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: [ :admin, @person, @position_assignment ] do |form| %>
    <p>
      <%= form.label :position_title_id, "Role" %>
      <%= form.collection_select :position_title_id, @position_titles, :id, :name %>
    </p>
    <p>
      <%= form.label :starts_on %>
      <%= form.date_field :starts_on %>
    </p>
    <%= form.submit "Assign role" %>
  <% end %>
</section>
