<h1>Administration</h1>

<p>Manage the roster import, accounts, permissions, and post roles.</p>

<p><%= link_to "People", admin_people_path, class: "button" %></p>
<p><%= link_to "Upload roster", new_admin_roster_import_path, class: "button" %></p>

<% if @latest_roster_import.present? %>
  <p>Latest successful roster import: <%= l(@latest_roster_import.imported_at, format: :long) %></p>
<% else %>
  <p>No roster has been imported yet.</p>
<% end %>

<% if @roster_stale %>
  <p role="alert">The roster is more than 30 days old or has not been imported yet. Upload a current National roster export.</p>
<% end %>
