<%= form_with model: [:admin, entry] do |form| %>
  <% if entry.seeded? %>
    <p class="page-sub">This changes your post's local copy only. It will not affect the original seed.</p>
  <% end %>
  <% if entry.errors.any? %>
    <div class="error-summary">
      <h2><%= pluralize(entry.errors.count, "error") %> prohibited this agenda item catalog entry from being saved:</h2>
      <ul>
        <% entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="fl">
    <%= form.label :title %>
    <%= form.text_field :title, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :slug %>
    <%= form.text_field :slug, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :category %>
    <%= form.select :category, AgendaItemCatalogEntry::CATEGORIES.map { |value, label| [label, value] }, {}, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :behavior_type %>
    <%= form.select :behavior_type, AgendaItemCatalogEntry::BEHAVIOR_TYPES.map { |value, label| [label, value] }, {}, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :position %>
    <%= form.number_field :position, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :active do %>
      <%= form.check_box :active %> Active
    <% end %>
  </div>
  <div class="fl">
    <%= form.label :summary %>
    <%= form.text_area :summary, class: "f", rows: 3 %>
  </div>
  <div class="fl">
    <%= form.label :body %>
    <%= form.rich_text_area :body %>
  </div>
  <div class="actions">
    <%= form.submit class: "btn-primary" %>
    <%= link_to "Cancel", admin_agenda_item_catalog_entries_path, class: "btn" %>
  </div>
<% end %>
