<%= form_with model: [:admin, entry], class: "stacked-form" do |form| %>
  <% if entry.seeded? %>
    <p class="page-sub">This changes your post's local copy only. It will not affect the original seed.</p>
  <% end %>
  <% if entry.errors.any? %>
    <div class="error-summary">
      <h2><%= pluralize(entry.errors.count, "error") %> prohibited this agenda item catalog entry from being saved:</h2>
      <ul>
        <% entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="fl">
    <%= form.label :title %>
    <%= form.text_field :title, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :summary, "Summary or guidance" %>
    <%= form.text_area :summary, class: "f", rows: 3 %>
  </div>
  <div class="fl">
    <%= form.label :body, "Wording" %>
    <p class="fl-help">Ceremony scripts, readings, or the full text officers read aloud. Leave blank for plain business items.</p>
    <%= form.rich_text_area :body %>
  </div>
  <div class="fl">
    <%= form.label :category, "Part of the meeting" %>
    <%= form.select :category, AgendaItemCatalogEntry::CATEGORIES.map { |value, label| [label, value] }, {}, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :behavior_type %>
    <p class="fl-help">How this item is used when you build agendas later.</p>
    <%= form.select :behavior_type, AgendaItemCatalogEntry::BEHAVIOR_TYPES.map { |value, label| [label, value] }, {}, class: "f" %>
  </div>
  <div class="fl">
    <%= form.label :active do %>
      <%= form.check_box :active %> Active
    <% end %>
  </div>
  <div class="btnrow">
    <%= form.submit "Save changes", class: "btn-primary" %>
    <%= link_to "Cancel", admin_agenda_item_catalog_entries_path, class: "btn-secondary" %>
  </div>
<% end %>
