<% content_for :title, "Agenda Item Catalog" %>
<% back_path = current_user.can?("manage_settings") ? admin_root_path : root_path %>
<% back_label = current_user.can?("manage_settings") ? "Administration" : "Dashboard" %>
<a class="back" href="<%= back_path %>">&larr; <%= back_label %></a>

<div class="page-lead">
  <h1 class="page-title">Agenda Item Catalog</h1>
  <p class="page-sub">These are the standard building blocks your post can use when creating meeting templates later. Select an item to edit its wording.</p>
</div>

<div class="btnrow">
  <%= link_to "Add catalog entry", new_admin_agenda_item_catalog_entry_path, class: "btn-primary" %>
</div>

<% @entries_by_category.each do |category, entries| %>
  <div class="sec-head-row" style="margin-top: 22px">
    <%= render "shared/section_header", label: AgendaItemCatalogEntry::CATEGORIES.fetch(category) %>
  </div>
  <div class="mrow-list">
    <% entries.each do |entry| %>
      <%= link_to edit_admin_agenda_item_catalog_entry_path(entry),
            class: "mrow catrow#{' mrow--inactive' unless entry.active?}",
            aria: { label: "Edit #{entry.title}" } do %>
        <span class="mrow-id">
          <span class="mrow-name"><%= entry.title %></span>
          <% if entry.summary.present? %><span class="mrow-sub"><%= entry.summary %></span><% end %>
        </span>
        <span class="catrow-meta">
          <% unless entry.active? %><%= agenda_active_tag(false) %><% end %>
          <% unless entry.seeded? %><span class="catrow-flag">Added by your post</span><% end %>
          <span class="catrow-edit">Edit<span class="catrow-caret" aria-hidden="true">&rsaquo;</span></span>
        </span>
      <% end %>
    <% end %>
  </div>
<% end %>
