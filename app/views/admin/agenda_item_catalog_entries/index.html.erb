<% content_for :title, "Agenda Item Catalog" %>
<% back_path = current_user.can?("manage_settings") ? admin_root_path : root_path %>
<% back_label = current_user.can?("manage_settings") ? "Administration" : "Dashboard" %>
<a class="back" href="<%= back_path %>">&larr; <%= back_label %></a>

<div class="page-lead">
  <h1 class="page-title">Agenda Item Catalog</h1>
  <p class="page-sub">These are the standard building blocks your post can use when creating meeting templates later.</p>
</div>

<div class="btnrow">
  <%= link_to "Add catalog entry", new_admin_agenda_item_catalog_entry_path, class: "btn-primary" %>
</div>

<% @entries_by_category.each do |category, entries| %>
  <div class="sec-head-row" style="margin-top: 22px">
    <%= render "shared/section_header", label: AgendaItemCatalogEntry::CATEGORIES.fetch(category) %>
  </div>
  <div class="mrow-list">
    <% entries.each do |entry| %>
      <div class="mrow<%= " mrow--inactive" unless entry.active? %>">
        <span class="mrow-id">
          <span class="mrow-l1">
            <span class="mrow-name"><%= entry.title %></span>
            <span class="mrow-tag"><%= entry.behavior_type_label %></span>
          </span>
          <% if entry.summary.present? %>
            <span class="mrow-sub"><%= entry.summary %></span>
          <% end %>
        </span>
        <span class="mrow-status mrow-status--actions">
          <span class="mrow-st"><%= agenda_active_tag(entry.active?) %></span>
          <span class="mrow-prov"><%= entry.seeded? ? entry.source_label : "Added by your post" %></span>
          <span class="mrow-actions">
            <%= link_to "Edit", edit_admin_agenda_item_catalog_entry_path(entry) %>
            <% if entry.active? %>
              <%= button_to "Deactivate", admin_agenda_item_catalog_entry_path(entry), method: :patch, params: { agenda_item_catalog_entry: { active: "0" } }, class: "mrow-btn" %>
            <% else %>
              <%= button_to "Reactivate", admin_agenda_item_catalog_entry_path(entry), method: :patch, params: { agenda_item_catalog_entry: { active: "1" } }, class: "mrow-btn" %>
            <% end %>
          </span>
        </span>
      </div>
    <% end %>
  </div>
<% end %>
