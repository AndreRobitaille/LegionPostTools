<% content_for :title, "Add catalog item to #{@meeting_type.name}" %>
<a class="back" href="<%= edit_admin_meeting_type_path(@meeting_type) %>">&larr; <%= @meeting_type.name %></a>

<div class="page-lead">
  <h1 class="page-title">Add catalog item</h1>
</div>

<div class="mrow-list">
  <% @entries_by_category.each do |category, entries| %>
    <div class="sec-head-row" style="margin-top: 22px">
      <%= render "shared/section_header", label: AgendaItemCatalogEntry::CATEGORIES.fetch(category) %>
    </div>
    <% entries.each do |entry, already_added| %>
      <div class="mrow catrow<%= ' mrow--inactive' unless entry.active? %>">
        <span class="mrow-id">
          <span class="mrow-name"><%= entry.title %></span>
          <% if entry.summary.present? %><span class="mrow-sub"><%= entry.summary %></span><% end %>
        </span>
        <span class="catrow-meta">
          <% unless entry.active? %><%= agenda_active_tag(false) %><% end %>
          <% if already_added %><span class="catrow-flag">Already added</span><% end %>
          <% unless already_added %>
            <%= button_to "Add", admin_meeting_type_agenda_items_path(@meeting_type, agenda_item_catalog_entry_id: entry.id), method: :post, class: "btn-secondary" %>
          <% end %>
        </span>
      </div>
    <% end %>
  <% end %>
</div>
