<%# app/views/people/_post_roles.html.erb
    Locals (from PeopleController#show, via _officer_person.html.erb and _member_person.html.erb):
    @person, @can_manage, and (officer only) @position_assignment, @position_titles.
    Read-only for members: mutation forms below only render when @can_manage. %>

<% roles = @person.position_assignments.sort_by { |assignment| [ assignment.ends_on.present? ? 1 : 0, assignment.starts_on ] }.reverse %>

<% if roles.any? %>
  <% roles.each do |assignment| %>
    <div class="role">
      <div class="role-top">
        <div>
          <div class="rn"><%= assignment.position_title.name %></div>
          <div class="rd">
            Since <%= legion_date(assignment.starts_on) %>
            <% if assignment.ends_on.present? %>
              &ndash; <%= legion_date(assignment.ends_on) %>
            <% else %>
              &middot; <span class="present">Present</span>
            <% end %>
          </div>
        </div>
        <% if @can_manage && assignment.ends_on.blank? %>
          <div class="role-actions">
            <%= button_to "End role", admin_person_position_assignment_path(@person, assignment), method: :patch,
                  params: { position_assignment: { ends_on: Date.current } }, class: "lnk warnlnk", form: { class: "inline" } %>
          </div>
        <% end %>
      </div>

      <% if @can_manage %>
        <div class="editbox">
          <%= form_with url: admin_person_position_assignment_path(@person, assignment), method: :patch, scope: :position_assignment do |form| %>
            <div class="editrow">
              <div class="fl">
                <label>Started</label>
                <%= render "shared/date_field", name: "position_assignment[starts_on]", value: assignment.starts_on %>
              </div>
              <div class="fl">
                <label>Ended</label>
                <%= render "shared/date_field", name: "position_assignment[ends_on]", value: assignment.ends_on %>
              </div>
              <%= form.submit "Save dates", class: "btn-primary btn-sm" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p class="page-sub">No post roles recorded.</p>
<% end %>

<% if @can_manage %>
  <div class="assign">
    <%= form_with url: admin_person_position_assignments_path(@person), method: :post, scope: :position_assignment do |form| %>
      <div class="fl">
        <%= form.label :position_title_id, "Role" %>
        <%= form.collection_select :position_title_id, @position_titles, :id, :name, { prompt: "Choose a role…" }, class: "f" %>
      </div>
      <div class="fl">
        <label>Starts on</label>
        <%= render "shared/date_field", name: "position_assignment[starts_on]", value: nil %>
      </div>
      <%= form.submit "Assign role", class: "btn-primary" %>
    <% end %>
  </div>
<% end %>
