<% content_for :title, "Security" %>

<nav class="page-bar" aria-label="Breadcrumb">
  <span class="page-bar-crumb">Settings</span>
  <span class="page-bar-sep">&rsaquo;</span>
  <span class="page-bar-here">Security</span>
</nav>

<div class="tabstrip">
  <span class="tabstrip-tab is-active">Security</span>
</div>

<section class="panel">
  <div class="panel-head">&#9670; Your passkeys</div>
  <p class="panel-lead">
    Passkeys let you sign in with your fingerprint, face, or device PIN instead of an email link.
    Give each one a name so you can tell your devices apart.
  </p>

  <% if @passkey_credentials.any? %>
    <ul class="pk-list">
      <% @passkey_credentials.each do |credential| %>
        <li class="pk-row" data-controller="rename">
          <div class="pk-row-info">
            <%= form_with url: passkey_path(credential), method: :patch, id: "rename-#{credential.id}" do |form| %>
              <%= form.text_field :nickname, value: credential.nickname, id: "pk-name-#{credential.id}",
                    class: "pk-name-field", autocomplete: "off", placeholder: "Unnamed passkey",
                    aria: { label: "Passkey name" }, data: { rename_target: "field" } %>
            <% end %>
            <p class="pk-row-meta">
              Added <%= credential.created_at.to_date.strftime("%b %-d, %Y") %><% if credential.last_used_at %> &middot; last used <%= credential.last_used_at.to_date.strftime("%b %-d, %Y") %><% end %>
            </p>
          </div>
          <div class="pk-row-actions">
            <button type="submit" form="rename-<%= credential.id %>" class="btn-secondary"
                    data-rename-target="button" data-action="rename#toggle">Rename</button>
            <%= button_to "Remove", passkey_path(credential), method: :delete,
                  class: "btn-return", form: { class: "pk-row-remove" },
                  data: { turbo_confirm: "Remove this passkey? You'll need the email link or another passkey to sign in on this device." } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="pk-empty">You have no passkeys yet. Add one below to sign in faster next time.</p>
  <% end %>

  <div class="pk-add-block" data-controller="passkey" data-passkey-redirect-value="/settings/security">
    <div class="panel-head panel-head--add">&#9670; Add a new passkey</div>
    <p class="panel-lead pk-add-lead">
      Register the device you're using right now — you'll be asked for your fingerprint, face, or device PIN.
    </p>
    <label class="pk-add-label" for="new-passkey-nickname">Name for this new passkey (optional)</label>
    <input class="pk-add-input" id="new-passkey-nickname" type="text" data-passkey-nickname
           placeholder="e.g. My iPhone or Office laptop" autocomplete="off">
    <button type="button" class="btn-primary" data-action="passkey#register" data-passkey-target="submit">
      Add a passkey
    </button>
    <p class="pk-card-status" data-passkey-target="status" role="status" aria-live="polite"></p>
  </div>
</section>
